<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/item_event"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/item_event_poster"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_margin="8dp"/>

        <TextView
            android:id="@+id/item_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textStyle="bold"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="@id/item_event_poster"
            app:layout_constraintStart_toEndOf="@id/item_event_poster"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/event_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Event Description goes here ..."
            android:maxLines="3"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/item_event_title"
            app:layout_constraintStart_toStartOf="@id/item_event_title"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/editUrl"
            android:text="EDIT"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintTop_toBottomOf="@id/event_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/viewAttendee" />
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/viewAttendee"
            android:text="Waiting"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintTop_toTopOf="@id/editUrl"
            app:layout_constraintStart_toEndOf="@id/editUrl"
            app:layout_constraintEnd_toStartOf="@id/viewAttendeeCancelled" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/viewAttendeeCancelled"
            android:text="Cancelled"
            android:layout_marginStart="4dp"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintTop_toTopOf="@id/viewAttendee"
            app:layout_constraintStart_toEndOf="@id/viewAttendee"
            app:layout_constraintEnd_toStartOf="@id/viewAttendeeSelected" />
        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/viewAttendeeSelected"
            android:layout_marginStart="4dp"
            android:text="Selected"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintTop_toTopOf="@id/viewAttendee"
            app:layout_constraintStart_toEndOf="@id/viewAttendeeCancelled"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/deleteEvent"
            android:visibility="gone"
            android:text="DELETE"
            app:layout_constraintTop_toBottomOf="@id/event_description"
            app:layout_constraintStart_toStartOf="@id/event_description"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/signUp_button"
            android:visibility="gone"
            android:text="Sign Up"
            app:layout_constraintTop_toBottomOf="@id/event_description"
            app:layout_constraintStart_toStartOf="@id/event_description"
            app:layout_constraintEnd_toEndOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>
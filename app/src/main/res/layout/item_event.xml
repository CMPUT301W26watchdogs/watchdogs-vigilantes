<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:id="@+id/item_event"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/item_event_poster"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/item_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Event Title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/item_event_poster"
            app:layout_constraintEnd_toStartOf="@id/statusBadge"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Beginner Swimming Lessons" />

        <TextView
            android:id="@+id/statusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_badge"
            android:text="OPEN"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/event_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="Event Description"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/item_event_poster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/item_event_title" />

        <TextView
            android:id="@+id/eventLocationInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:drawablePadding="4dp"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/item_event_poster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/event_description"
            tools:text="Mar 10 - Kinsmen Sports Centre" />

        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toEndOf="@id/item_event_poster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/eventLocationInfo">

            <TextView
                android:id="@+id/waitingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/status_waiting"
                android:textStyle="bold"
                android:layout_marginEnd="12dp"
                tools:text="47 Waiting" />

            <TextView
                android:id="@+id/spotsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                tools:text="20 spots" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/orgButtonRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/statsRow">

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:id="@+id/editUrl"
                android:text="Edit"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:id="@+id/viewAttendee"
                android:text="Waiting"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/orgButtonRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/orgButtonRow1">

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:id="@+id/viewAttendeeCancelled"
                android:text="Cancelled"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:id="@+id/viewAttendeeSelected"
                android:text="Selected"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:id="@+id/viewAttendeeEnrolled"
                android:text="Enrolled"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:id="@+id/deleteEvent"
            android:visibility="gone"
            android:text="REMOVE"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/vigilante_red"
            android:layout_marginTop="8dp"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/orgButtonRow2" />

        <com.google.android.material.button.MaterialButton
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:id="@+id/signUp_button"
            android:visibility="gone"
            android:text="Sign Up"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            app:cornerRadius="10dp"
            app:layout_constraintTop_toBottomOf="@id/orgButtonRow2" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

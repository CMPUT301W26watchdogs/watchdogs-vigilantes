<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notifCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_gray"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="@color/vigilante_red">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@android:color/white"
                android:contentDescription="Notification" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/vigilante_red"
                tools:text="You've been selected!" />

            <TextView
                android:id="@+id/notifMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                tools:text="A spot opened up and you were drawn from the waitlist." />

            <com.google.android.material.chip.Chip
                android:id="@+id/notifEventChip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                app:chipBackgroundColor="@color/vigilante_red"
                app:chipCornerRadius="8dp"
                app:chipMinHeight="28dp"
                app:chipIconTint="@android:color/white"
                app:chipIcon="@android:drawable/ic_menu_today"
                tools:text="Ved Sport Event" />

        </LinearLayout>

        <View
            android:id="@+id/unreadDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="@color/vigilante_red"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

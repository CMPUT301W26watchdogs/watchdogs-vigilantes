<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_add_event"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/add_event_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New Event"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <EditText
        android:id="@+id/event_title_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Event Title"
        android:inputType="textCapWords"
        app:layout_constraintTop_toBottomOf="@id/add_event_header"
        android:layout_marginTop="32dp" />

    <EditText
        android:id="@+id/event_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Event Description"
        android:inputType="textMultiLine"
        android:lines="5"
        android:gravity="top|start"
        app:layout_constraintTop_toBottomOf="@id/event_title_input"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/et_poster_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste Image Link (e.g http://imgur.com/photo.jpg"
        android:inputType="textUri"
        app:layout_constraintTop_toBottomOf="@id/event_description"
        android:layout_marginTop="8dp"/>
    <Button
        android:id="@+id/publish_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Publish Event"
        app:layout_constraintTop_toBottomOf="@id/et_poster_url"
        android:layout_marginTop="32dp" />

    <Button
        android:id="@+id/back_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Go Back"
        app:layout_constraintTop_toBottomOf="@id/publish_button"
        android:layout_marginBottom="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>